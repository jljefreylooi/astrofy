---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout title="Projects" sideBarActiveItemID="projects">
  <div>
    <div class="text-3xl w-full font-bold mb-5">Projects & Case Studies</div>
  </div>

  <HorizontalCard
    title="F&B Retail Outlet Handover"
    img="/post_img.webp" 
    desc="End-to-end renovation management for high-traffic milk tea and coffee shops. Managed tight construction timelines, sub-contractors, and zero-delay handovers."
    url="#"
    badge="Retail"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Industrial HVAC System Installation"
    img="/post_img.webp"
    desc="Large-scale HVAC and air compressor engineering integration. Optimized material configurations to meet strict project budget boundaries."
    url="#"
    badge="Engineering"
  />
</BaseLayout>
