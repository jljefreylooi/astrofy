---
import BaseLayout from "../layouts/BaseLayout.astro";
import TimeLineElement from "../components/cv/TimeLine.astro";
---

<BaseLayout title="Resume" sideBarActiveItemID="cv">
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Experience</div>
  </div>

  <div class="time-line-container mb-10">
    <TimeLineElement
      title="Project Manager"
      subtitle="Jan 2026 – Present at YIZU SHANGZHUANG Sdn Bhd"
    >
      Managing retail store renovations for Milk Tea & Coffee shops. Coordinating construction supervision, daily progress tracking, and rapid handling of on-site emergencies.
    </TimeLineElement>
    <TimeLineElement
      title="Maintenance & Project Lead"
      subtitle="2021 – 2025 at June Air Engineering Sdn Bhd"
    >
      Oversaw industrial HVAC and air compressor engineering projects. Directed field teams and executed material budget optimization.
    </TimeLineElement>
    <TimeLineElement
      title="Firefighter (Unit S.T.O.R.M)"
      subtitle="2019 – 2021 at Jabatan Bomba dan Penyelamat Malaysia"
    >
      Deployed on high-risk special rescue missions. Maintained tactical combat readiness and structural crisis management.
    </TimeLineElement>
  </div>
</BaseLayout>
